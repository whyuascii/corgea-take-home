# Postgres
POSTGRES_DB=vulntracker
POSTGRES_USER=vulntracker
POSTGRES_PASSWORD=vulntracker_dev_password

# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=dev-secret-key-change-in-production
FIELD_ENCRYPTION_KEY=dev-encryption-key-do-not-use-in-production
DATABASE_URL=postgresql://vulntracker:vulntracker_dev_password@db:5432/vulntracker
ALLOWED_HOSTS=*
FIELD_ENCRYPTION_SALT=vulntracker-field-encryption

# Proxy (set to 1 if behind a load balancer, 0 for direct connections)
TRUSTED_PROXY_COUNT=0

# Email (Resend)
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=VulnTracker <noreply@vulntracker.dev>
VULNTRACKER_BASE_URL=http://localhost:3000

# Data Retention
DATA_RETENTION_DAYS=90
